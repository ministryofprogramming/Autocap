# =============================================================================
# AutoCap Web (Next.js) - Environment Variables (example)
# =============================================================================
#
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored.
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to browser code — do not
# put secrets in them. Everything else is server-only (Server Components,
# Route Handlers, Middleware).
# =============================================================================

# -----------------------------------------------------------------------------
# Mapbox — public token (browser-exposed; OK to ship)
# -----------------------------------------------------------------------------
# Get yours at https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# -----------------------------------------------------------------------------
# Strapi CMS — read-only fetch from the AutoCap CMS workspace
# -----------------------------------------------------------------------------
# Server-only. Used by `src/lib/cms/client.ts` (Server Components / ISR).
# Local dev: points to the Strapi dev server (cd ../cms && npm run develop).
CMS_API_URL=http://localhost:1337

# Strapi API token with write scope — used by the contact form route handler
# to persist submissions to Strapi. Generate in Strapi admin:
# Settings → API Tokens → Create → Full Access or custom with contact-submission:create.
STRAPI_API_TOKEN=

# -----------------------------------------------------------------------------
# Site URL — future, for canonical URLs / SEO / OpenGraph
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_URL=https://autocapgroup.se

# -----------------------------------------------------------------------------
# Revalidation webhook — future, when ISR-on-publish is wired up
# -----------------------------------------------------------------------------
# Must match REVALIDATE_SECRET in cms/.env. Strapi calls
# `${NEXT_PUBLIC_SITE_URL}/api/revalidate?secret=...&path=...`
# when an editor publishes; Next.js purges the ISR cache for that path.
# REVALIDATE_SECRET=replace_with_strong_random_string

# -----------------------------------------------------------------------------
# Email — Resend (contact form submissions)
# -----------------------------------------------------------------------------
# Used by `src/lib/contact/emailService.ts` via POST /api/contact/general.
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_...

# Recipient address for contact form emails. Defaults to kontakt@autocapgroup.se.
CONTACT_EMAIL_TO=kontakt@autocapgroup.se

# ISR revalidation intervals in seconds. Defaults: HIGH=3600, LOW=300.
# Set to a low value (e.g. 10) on demo/staging for instant content updates.
# REVALIDATE_HIGH=3600
# REVALIDATE_LOW=300

# -----------------------------------------------------------------------------
# i18n — Swedish locale feature flag
# -----------------------------------------------------------------------------
# Set to "true" to enable the /sv/... routes and show the language selector.
# Keep "false" until Swedish translations are ready.
NEXT_PUBLIC_ENABLE_SV=false
